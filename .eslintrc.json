{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "globals": {
    "showNotification": "readonly",
    "updateLeaderboard": "readonly",
    "updateProfile": "readonly",
    "saveUserData": "readonly",
    "userProgress": "writable",
    "cachedSession": "writable",
    "renderPersonalityCard": "readonly",
    "renderMistakeDnaCard": "readonly",
    "openQuizEditor": "readonly",
    "addXP": "readonly",
    "recordAnalyticsEvent": "readonly",
    "recordDailyActivity": "readonly",
    "handleQuizCompletionForRevision": "readonly",
    "updateDashboard": "readonly",
    "updateGamification": "readonly"
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-undef": "error"
  }
}
